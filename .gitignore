# ==========================================
# 1. Backend / Python Rules
# ==========================================
# Virtual Environment
backend/.venv/
backend/venv/
backend/env/
backend/.env/

# Python caching & bytecode
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Environment variables & secrets (CRITICAL)
backend/.env
backend/.env.*
!.env.example


# ==========================================
# 2. Frontend / Node.js Rules
# ==========================================
# Dependencies
frontend/ecommerce/node_modules/

# Production builds
frontend/ecommerce/dist/
frontend/ecommerce/build/

# Frontend local env keys (if any)
frontend/ecommerce/.env.local
frontend/ecommerce/.env.*.local


# ==========================================
# 3. Global / OS / IDE Rules
# ==========================================
# macOS system files
.DS_Store

# JetBrains / VS Code configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln